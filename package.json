{
  "name": "guidemygrid",
  "version": "1.6.0",
  "description": "Plugin UXP para Adobe Photoshop — generador de retículas de columnas",
  "private": true,
  "scripts": {
    "prebuild": "node scripts/sync-version.js",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "package": "npm run build && node scripts/package.js",
    "release:patch": "npm version patch && npm run package",
    "release:minor": "npm version minor && npm run package",
    "release:major": "npm version major && npm run package",
    "publish:patch": "npm run release:patch && git push && git push --tags",
    "publish:minor": "npm run release:minor && git push && git push --tags",
    "publish:major": "npm run release:major && git push && git push --tags"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "css-loader": "^6.8.0",
    "eslint": "^8.0.0",
    "html-webpack-plugin": "^5.5.0",
    "jest": "^29.0.0",
    "mini-css-extract-plugin": "^2.10.0",
    "style-loader": "^3.3.0",
    "ts-jest": "^29.0.0",
    "ts-loader": "^9.4.0",
    "typescript": "^5.0.0",
    "webpack": "^5.88.0",
    "webpack-cli": "^5.1.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts",
      "**/__tests__/**/*.test.tsx"
    ]
  }
}
